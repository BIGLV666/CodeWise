<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.servicequestion.mapper.TestCaseMapper">
    <delete id="deleteByQuestionIds">
        DELETE FROM test_case
        WHERE question_id IN
        <foreach collection="list" item="questionId" open="(" close=")" separator=",">
            #{questionId}
        </foreach>
    </delete>
    <select id="countTestCasesByQuestionId" resultType="java.util.HashMap">
        SELECT
            question_id,
            COUNT(*) AS count
        FROM test_case
        GROUP BY question_id
        ORDER BY question_id ASC
    </select>

</mapper>